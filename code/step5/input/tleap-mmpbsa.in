source leaprc.protein.ff14SB
source leaprc.water.tip3p
source leaprc.gaff2
addAtomTypes { { "ZN" "Zn" "sp3" } { "S3" "S" "sp3" } { "N2" "N" "sp3" } }
loadamberprep STEP4_MODEL_INPUTS/ZAFF.prep #Load ZAFF prep file
loadamberparams STEP4_MODEL_INPUTS/ZAFF.frcmod #Load ZAFF frcmod file

frcmod = loadamberparams STEP4_ITR_DIR/par-gen/LIG/LIG.frcmod

prot = loadpdb STEP4_MODEL_INPUTS/prot-pdb4amber-nowat.pdb
UNL = loadmol2 STEP4_ITR_DIR/par-gen/LIG/LIG.mol2
lig = loadpdb lig_pose.pdb

bond prot.209.ZN prot.130.SG
bond prot.209.ZN prot.133.ND1
bond prot.209.ZN prot.138.SG
bond prot.209.ZN prot.141.SG

com = combine {prot lig}

saveamberparm prot rec.top rec.crd
saveamberparm lig lig.top lig.crd
saveamberparm com com.top com.crd

quit
